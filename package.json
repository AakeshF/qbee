{
  "name": "qbee",
  "version": "0.0.0",
  "private": true,
  "description": "QBee — your own Cursor: VSCode fork with first-class AI",
  "license": "MIT",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm --filter shared build && pnpm --filter spa build && pnpm --filter worker build && bash scripts/vendor-spa.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "vendor-spa": "bash scripts/vendor-spa.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
